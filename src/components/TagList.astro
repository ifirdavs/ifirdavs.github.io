---
interface Props {
  tags: string[];
}

const { tags } = Astro.props as Props;
---

<ul class="flex flex-wrap gap-2" aria-label="Post tags">
  {
    tags.map((tag) => (
      <li class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm font-semibold text-slate-700 dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-200">
        {tag}
      </li>
    ))
  }
</ul>
