---
import type { CollectionEntry } from 'astro:content';
import { formatDisplayDate, postUrl } from '../lib/blog';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props as Props;
---

<article class="group surface h-full px-6 py-6 transition duration-300 hover:-translate-y-1 hover:shadow-[0_26px_90px_-36px_rgba(14,165,233,0.35)]">
  <div class="flex h-full flex-col gap-4">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">
      {formatDisplayDate(post.data.pubDate)}
    </p>

    <h3 class="text-2xl font-semibold text-slate-950 transition group-hover:text-sky-700 dark:text-white dark:group-hover:text-sky-300">
      <a href={postUrl(post)}>{post.data.title}</a>
    </h3>

    <p class="flex-1 text-base leading-7 text-slate-700 dark:text-slate-300">
      {post.data.description}
    </p>

    <div>
      <a
        href={postUrl(post)}
        class="inline-flex items-center rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-900 hover:border-sky-400 hover:text-sky-700 dark:border-slate-700 dark:text-slate-100 dark:hover:border-sky-500 dark:hover:text-sky-300"
      >
        Read More
      </a>
    </div>
  </div>
</article>
