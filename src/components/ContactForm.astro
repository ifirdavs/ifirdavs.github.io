---
import { siteConfig } from '../data/site';

const hasPlaceholderEmail = siteConfig.contact.email.includes('replace-with-your-email');
---

<div class="surface px-6 py-8 md:px-8">
  <div class="mb-6 space-y-2">
    <h2 class="text-3xl font-semibold text-slate-950 dark:text-white">Send a message</h2>
    <p class="text-base leading-7 text-slate-700 dark:text-slate-300">
      This form uses your default email client. Once submitted, it opens a prefilled email to
      <a
        class="font-semibold text-sky-700 underline decoration-sky-300 underline-offset-4 dark:text-sky-300 dark:decoration-sky-700"
        href={`mailto:${siteConfig.contact.email}`}
      >
        {siteConfig.contact.email}
      </a>
      .
    </p>
    {
      hasPlaceholderEmail && (
        <p class="rounded-2xl border border-orange-200 bg-orange-50 px-4 py-3 text-sm text-orange-900 dark:border-orange-900/60 dark:bg-orange-950/40 dark:text-orange-200">
          Update the placeholder recipient in <code>src/data/site.ts</code> before going live.
        </p>
      )
    }
  </div>

  <form data-contact-form data-recipient={siteConfig.contact.email} class="grid gap-5" novalidate>
    <div class="grid gap-5 md:grid-cols-2">
      <label class="grid gap-2 text-sm font-semibold text-slate-800 dark:text-slate-200">
        Name
        <input
          class="rounded-2xl border border-slate-300 bg-white px-4 py-3 text-base font-normal text-slate-900 outline-none ring-0 transition placeholder:text-slate-400 focus:border-sky-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100"
          type="text"
          name="name"
          autocomplete="name"
          placeholder="Your name"
          required
        />
      </label>

      <label class="grid gap-2 text-sm font-semibold text-slate-800 dark:text-slate-200">
        Email
        <input
          class="rounded-2xl border border-slate-300 bg-white px-4 py-3 text-base font-normal text-slate-900 outline-none ring-0 transition placeholder:text-slate-400 focus:border-sky-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100"
          type="email"
          name="email"
          autocomplete="email"
          placeholder="you@example.com"
          required
        />
      </label>
    </div>

    <label class="grid gap-2 text-sm font-semibold text-slate-800 dark:text-slate-200">
      Subject
      <input
        class="rounded-2xl border border-slate-300 bg-white px-4 py-3 text-base font-normal text-slate-900 outline-none ring-0 transition placeholder:text-slate-400 focus:border-sky-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100"
        type="text"
        name="subject"
        autocomplete="off"
        placeholder="Project inquiry, collaboration, or hello"
        required
      />
    </label>

    <label class="grid gap-2 text-sm font-semibold text-slate-800 dark:text-slate-200">
      Message
      <textarea
        class="min-h-44 rounded-[1.5rem] border border-slate-300 bg-white px-4 py-3 text-base font-normal text-slate-900 outline-none ring-0 transition placeholder:text-slate-400 focus:border-sky-500 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100"
        name="message"
        placeholder="Tell me a little about what you have in mind."
        required
      ></textarea>
    </label>

    <p data-form-message class="text-sm text-slate-600 dark:text-slate-400" aria-live="polite">
      Required fields are validated before your email app opens.
    </p>

    <div class="flex flex-wrap items-center gap-4">
      <button type="submit" class="button-primary">Open Email Client</button>
      <a class="button-secondary" href={`mailto:${siteConfig.contact.email}`}>Use Plain Email Link</a>
    </div>
  </form>
</div>

<script>
  const form = document.querySelector('[data-contact-form]');
  const message = document.querySelector('[data-form-message]');

  if (form instanceof HTMLFormElement && message instanceof HTMLElement) {
    form.addEventListener('submit', (event) => {
      event.preventDefault();

      if (!form.checkValidity()) {
        message.textContent = 'Please complete every required field with a valid email address.';
        form.reportValidity();
        return;
      }

      const formData = new FormData(form);
      const recipient = form.dataset.recipient ?? '';
      const name = String(formData.get('name') ?? '').trim();
      const email = String(formData.get('email') ?? '').trim();
      const subject = String(formData.get('subject') ?? '').trim();
      const bodyMessage = String(formData.get('message') ?? '').trim();

      const mailSubject = `[Website] ${subject}`;
      const mailBody = [
        `Name: ${name}`,
        `Email: ${email}`,
        `Subject: ${subject}`,
        '',
        bodyMessage,
      ].join('\n');

      const mailtoUrl = `mailto:${recipient}?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;

      message.textContent = 'Opening your default email client...';
      window.location.href = mailtoUrl;
    });
  }
</script>
