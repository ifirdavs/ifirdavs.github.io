---
import { siteConfig } from '../data/site';

const currentPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const isActive = (href: string) =>
  href === '/blog/' ? currentPath.startsWith('/blog/') : currentPath === href;
---

<header class="section-shell relative z-10 pt-6">
  <div class="surface flex flex-col gap-5 px-6 py-5 md:flex-row md:items-center md:justify-between">
    <a
      href="/"
      class="max-w-max text-2xl font-semibold text-slate-950 hover:text-sky-700 dark:text-white dark:hover:text-sky-300"
    >
      {siteConfig.title}
    </a>

    <nav aria-label="Primary navigation">
      <ul class="flex flex-wrap items-center gap-2 text-sm font-semibold text-slate-600 dark:text-slate-300">
        {
          siteConfig.navigation.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'inline-flex rounded-full px-4 py-2 transition',
                  item.external
                    ? 'hover:bg-white/70 hover:text-sky-700 dark:hover:bg-slate-900 dark:hover:text-sky-300'
                    : isActive(item.href)
                      ? 'bg-slate-950 text-white dark:bg-sky-300 dark:text-slate-950'
                      : 'hover:bg-white/70 hover:text-sky-700 dark:hover:bg-slate-900 dark:hover:text-sky-300',
                ]}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noreferrer' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
