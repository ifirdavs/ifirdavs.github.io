---
import SocialLinks from './SocialLinks.astro';
import { siteConfig } from '../data/site';
---

<footer class="section-shell pb-10">
  <div class="surface flex flex-col gap-6 px-6 py-8 md:flex-row md:items-center md:justify-between">
    <div class="space-y-2">
      <p class="text-lg font-semibold text-slate-950 dark:text-white">{siteConfig.title}</p>
      <p class="text-sm text-slate-600 dark:text-slate-400">{siteConfig.copyright}</p>
    </div>

    <SocialLinks showLabels={false} />
  </div>
</footer>
